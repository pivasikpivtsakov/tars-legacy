msgid "start.welcome"
msgstr "Welcome! Pick a section below."

msgid "start.btn_online_on"
msgstr "Go online"

msgid "start.btn_online_off"
msgstr "Go offline"

msgid "start.btn_balance"
msgstr "Balance"

msgid "start.btn_withdraw"
msgstr "Withdraw"

msgid "start.btn_packs"
msgstr "Packs / price"

msgid "start.btn_priority"
msgstr "Priority"

msgid "start.btn_register"
msgstr "Register / edit profile"

msgid "start.btn_back"
msgstr "Back"

msgid "start.online_now_on"
msgstr "You are now online."

msgid "start.online_now_off"
msgstr "You are now offline."

msgid "start.priority"
msgstr "Your priority:\nspeed: {speed}\nprice: {price}\ncompleted (strict): {rate_strict}%\ncompleted (incl. not-picked): {rate_full}%"

msgid "start.balance"
msgstr "Your balance: {balance}"

msgid "start.profile_required"
msgstr "Finish registration first."

msgid "withdraw.placeholder"
msgstr "Withdrawal flow is not wired yet. Tap Back to return."

msgid "packs.title"
msgstr "Toggle the packages you make, then press Back."

msgid "registration.ask_works_alone"
msgstr "Do you work alone?"

msgid "registration.btn_yes"
msgstr "Yes"

msgid "registration.btn_no"
msgstr "No"

msgid "registration.ask_packages"
msgstr "Which packages do you make? Toggle as many as you want, then press Done."

msgid "registration.btn_done"
msgstr "Done"

msgid "registration.no_packages_selected"
msgstr "Pick at least one package."

msgid "registration.ask_price"
msgstr "What is your price for the 60 UC pack? Send a whole number, e.g. 60."

msgid "registration.invalid_price"
msgstr "I couldn't parse that. Please send a positive whole number, e.g. 60."

msgid "registration.ask_withdrawal_method"
msgstr "How do you withdraw your money?"

msgid "registration.ask_work_start"
msgstr "What time do you start working? (HH:MM, Moscow time)"

msgid "registration.ask_work_end"
msgstr "What time do you finish working? (HH:MM, Moscow time)"

msgid "registration.invalid_time"
msgstr "I couldn't parse that. Please send the time as HH:MM, e.g. 09:30."

msgid "registration.work_end_before_start"
msgstr "End time must be later than start time. Please send the end time again."

msgid "registration.done"
msgstr "Got it: solo={works_alone}, packages={packages}, price/60={price_60}, withdrawal={withdrawal_method}, work={work_start}-{work_end} MSK."

msgid "registration.restarted"
msgstr "Restarted. Send /register to start again."

msgid "registration.nothing_to_restart"
msgstr "Nothing to restart."

msgid "registration.finished_filling"
msgstr "Registration already finished. Use /start to open the menu."

msgid "unknown"
msgstr "I don't understand that. Try /start."

msgid "order.offer"
msgstr "<b>New order</b>\nID: <code>{order_id}</code>\nUC: <b>{amount}</b>\nPrice: <b>{full_price}</b>"

msgid "order.btn_take"
msgstr "Take"

msgid "order.taken"
msgstr "<b>Order in progress</b>\nID: <code>{order_id}</code>\nUC: <b>{amount}</b>\nPUBG ID: <code>{pubg_id}</code>"

msgid "order.codes_line"
msgstr "Codes: <code>{codes}</code>"

msgid "order.btn_ready"
msgstr "Ready"

msgid "order.btn_cancel"
msgstr "Cancel"

msgid "order.completed"
msgstr "Order #{order_id} completed. Thanks!"

msgid "order.cancelled"
msgstr "Order #{order_id} cancelled."

msgid "order.unavailable"
msgstr "This order is no longer available."

msgid "order.limit_reached"
msgstr "You already have 3 orders in progress."
