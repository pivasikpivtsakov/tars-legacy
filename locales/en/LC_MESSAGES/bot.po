msgid "welcome"
msgstr "Hi there! Send /form to start the demo flow, or /restart to abort."

msgid "form.ask_works_alone"
msgstr "Do you work alone?"

msgid "form.btn_yes"
msgstr "Yes"

msgid "form.btn_no"
msgstr "No"

msgid "form.ask_packages"
msgstr "Which packages do you make? Toggle as many as you want, then press Done."

msgid "form.btn_done"
msgstr "Done"

msgid "form.no_packages_selected"
msgstr "Pick at least one package."

msgid "form.ask_withdrawal_method"
msgstr "How do you withdraw your money?"

msgid "form.ask_work_start"
msgstr "What time do you start working? (HH:MM, Moscow time)"

msgid "form.ask_work_end"
msgstr "What time do you finish working? (HH:MM, Moscow time)"

msgid "form.invalid_time"
msgstr "I couldn't parse that. Please send the time as HH:MM, e.g. 09:30."

msgid "form.work_end_before_start"
msgstr "End time must be later than start time. Please send the end time again."

msgid "form.done"
msgstr "Got it: solo={works_alone}, packages={packages}, withdrawal={withdrawal_method}, work={work_start}-{work_end} MSK. Send /form to try again."

msgid "form.restarted"
msgstr "Restarted. Send /form to start again."

msgid "form.nothing_to_restart"
msgstr "Nothing to restart."

msgid "form.finished_filling"
msgstr "Form finished filling."

msgid "unknown"
msgstr "I don't understand that. Try /form."
