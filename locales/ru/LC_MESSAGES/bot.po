msgid "start.welcome"
msgstr "Добро пожаловать! Выбери раздел ниже."

msgid "start.btn_online_on"
msgstr "Войти онлайн"

msgid "start.btn_online_off"
msgstr "Выйти оффлайн"

msgid "start.btn_balance"
msgstr "Баланс"

msgid "start.btn_withdraw"
msgstr "Вывод денег"

msgid "start.btn_packs"
msgstr "Паки / цена"

msgid "start.btn_priority"
msgstr "Приоритет"

msgid "start.btn_register"
msgstr "Регистрация / изменить профиль"

msgid "start.btn_back"
msgstr "Назад"

msgid "start.btn_menu"
msgstr "☰ Меню"

msgid "start.menu_hint"
msgstr "Нажми кнопку «☰ Меню» внизу, чтобы открыть меню в любой момент."

msgid "start.online_now_on"
msgstr "Ты теперь онлайн."

msgid "start.online_now_off"
msgstr "Ты теперь оффлайн."

msgid "start.priority"
msgstr "Твой приоритет:\nскорость: {speed}\nцена: {price}\nвыполнено (строго): {rate_strict}%\nвыполнено (с непринятыми): {rate_full}%"

msgid "start.balance"
msgstr "Твой баланс: {balance}"

msgid "start.profile_required"
msgstr "Сначала заверши регистрацию."

msgid "start.on_moderation"
msgstr "Твой профиль на модерации. Дождись проверки администратором. Профиль можно изменить ниже."

msgid "start.banned"
msgstr "Твой аккаунт заблокирован."

msgid "start.approved"
msgstr "Тебя одобрили! Добро пожаловать."

