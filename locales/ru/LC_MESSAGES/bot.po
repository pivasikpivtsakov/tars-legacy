msgid "withdraw.placeholder"
msgstr "Вывод средств пока не подключён. Нажми «Назад», чтобы вернуться."

msgid "packs.title"
msgstr "Отметь пакеты, которые делаешь, и нажми «Назад»."

msgid "registration.ask_works_alone"
msgstr "Ты работаешь один?"

msgid "registration.btn_yes"
msgstr "Да"

msgid "registration.btn_no"
msgstr "Нет"

msgid "registration.ask_packages"
msgstr "Какие пакеты ты делаешь? Отметь сколько нужно и нажми «Готово»."

msgid "registration.btn_done"
msgstr "Готово"

msgid "registration.no_packages_selected"
msgstr "Выбери хотя бы один пакет."

msgid "registration.ask_price"
msgstr "Какая твоя цена за пак 60 UC? Пришли целое число, например 60."

msgid "registration.invalid_price"
msgstr "Не получилось распознать цену. Пришли положительное целое число, например 60."

msgid "registration.ask_withdrawal_method"
msgstr "Каким способом ты выводишь деньги?"

msgid "registration.ask_work_start"
msgstr "Во сколько ты начинаешь работу? (формат HH:MM, по МСК)"

msgid "registration.ask_work_end"
msgstr "Во сколько ты заканчиваешь работу? (формат HH:MM, по МСК)"

msgid "registration.invalid_time"
msgstr "Не получилось распознать время. Отправь его в формате HH:MM, например 09:30."

msgid "registration.work_end_before_start"
msgstr "Время окончания должно быть позже времени начала. Пришли время окончания ещё раз."

msgid "registration.done"
msgstr "Записал: один={works_alone}, пакеты={packages}, цена/60={price_60}, вывод={withdrawal_method}, работа={work_start}-{work_end} МСК."

msgid "registration.finished_filling"
msgstr "Регистрация уже завершена. Отправь /start, чтобы открыть меню."

msgid "unknown"
msgstr "Не понимаю. Попробуй /start."

msgid "order.offer"
msgstr "<b>Новый заказ</b>\nID: <code>{order_id}</code>\nUC: <b>{amount}</b>\nЦена: <b>{full_price}</b>"

msgid "order.btn_take"
msgstr "Взять"

msgid "order.expired"
msgstr "<i>Истекло</i>"

msgid "order.taken"
msgstr "<b>Заказ в работе</b>\nID: <code>{order_id}</code>\nUC: <b>{amount}</b>\nPUBG ID: <code>{pubg_id}</code>"

msgid "order.codes_header"
msgstr "Коды:"

msgid "order.codes_line"
msgstr "{key}: <code>{value}</code>"

msgid "order.btn_ready"
msgstr "Готово"

msgid "order.btn_cancel"
msgstr "Отменить"

msgid "order.completed"
msgstr "Заказ #{order_id} выполнен. Спасибо!"

msgid "order.cancelled"
msgstr "Заказ #{order_id} отменён."

msgid "order.unavailable"
msgstr "Этот заказ уже недоступен."

msgid "order.limit_reached"
msgstr "У тебя уже 3 заказа в работе."

msgid "order.offline"
msgstr "Ты оффлайн. Перейди в онлайн, чтобы брать заказы."
