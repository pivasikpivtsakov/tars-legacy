# Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to run /# admin commands.
# Leave empty to disable admin commands entirely.
ADMIN_USER_IDS=

# Postgres (consumed by both the app and docker compose)
RDS_HOSTNAME=localhost
RDS_PORT=5433
RDS_USERNAME=app
RDS_PASSWORD=app
RDS_DB_NAME=app

# Redis (FSM storage for aiogram)
REDIS_URL=redis://localhost:6379/0

# Scheduler (interval between periodic ticks, in seconds)
SCHEDULER_INTERVAL_SECONDS=30

# Logging
LOG_LEVEL=INFO

# i18n
DEFAULT_LOCALE=en
