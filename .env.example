# Telegram
TELEGRAM_BOT_TOKEN=

# Admin and moderator user IDs live in Redis (sets keyed by
# settings:role_user_ids:admin / settings:role_user_ids:moderator) and hold the
# internal user_profiles.id values (not Telegram IDs). Seed them with redis-cli,
# e.g. SADD settings:role_user_ids:admin <profile_id>. Admins run /# commands and
# bypass the bot switch; moderators never receive orders, only registration
# approval requests. Empty sets disable admin commands / moderation respectively.

# Postgres (consumed by both the app and docker compose)
RDS_HOSTNAME=localhost
RDS_PORT=5433
RDS_USERNAME=app
RDS_PASSWORD=app
RDS_DB_NAME=app

# Redis (aiogram FSM storage and rating stats)
REDIS_URL=redis://localhost:6379/0

# Dispatcher backstop sweep interval (seconds) for any wake signals that get missed
DISPATCH_BACKSTOP_SECONDS=30

# Max orders pulled from the backlog per dispatcher sweep
DISPATCH_BATCH_LIMIT=100

# How often (seconds) the timekeeper polls for due offer expiries
OFFER_EXPIRY_POLL_SECONDS=1

# How long (seconds) an offered order stays takeable before it expires
OFFER_TTL_SECONDS=30

# Rating (how many recent completed orders feed the speed average)
RATING_SPEED_WINDOW=3

# Max orders a user can have pending-to-pick or in progress at once
MAX_ORDERS_PENDING=3

# Logging
LOG_LEVEL=INFO
# Output format: 'json' for structured prod logs (Grafana/Loki), 'console' for a colored TTY
LOG_FORMAT=json
# Level for aiogram's per-update handler/duration logger (does not include user id)
AIOGRAM_EVENT_LOG_LEVEL=WARNING

# i18n
DEFAULT_LOCALE=en

# External controller API
APP_ENVIRONMENT=local
API_URL=https://api.example.com
API_TOKEN=
API_TIMEOUT=15

# FastAPI server bind address (this app, not the upstream controller)
API_HOST=0.0.0.0
API_PORT=8000
